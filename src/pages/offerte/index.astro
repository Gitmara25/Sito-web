---
import CardOfferte from "./components/CardOfferte.astro";
import Button from "../../components/Button.astro";
import Layout from "../../layouts/Layout.astro";
import CardBenefit from "./components/CardBenefit.astro";
import CardOfferteGenerator from "../../components/CardOfferteGenerator.astro";
import DataScadenza from "../../components/DataScadenza.astro";
---

<Layout metadescription='meta description for SEO, EDIT IT'>
  <section>
    <div class='bg-red-700 py-4'>
      <h1 class='text-center'>Offerte</h1>
      <p class='mb-8 text-center'>
        Affrettati, offerta a tempo limitato
        <DataScadenza />
      </p>
    </div>

    <!-- Benefit -->
    <div class='marginx flex gap-4 justify-around flex-wrap items-center'>
      <CardBenefit>
        <svg
          xmlns='http://www.w3.org/2000/svg'
          viewBox='0 0 256 256'
          height='64'
          width='64'
          fill='#ac1b1b'
          ><path
            d='M255.43,117l-14-35A15.93,15.93,0,0,0,226.58,72H192V64a8,8,0,0,0-8-8H32A16,16,0,0,0,16,72V184a16,16,0,0,0,16,16H49a32,32,0,0,0,62,0h50a32,32,0,0,0,62,0h17a16,16,0,0,0,16-16V120A8.13,8.13,0,0,0,255.43,117ZM80,208a16,16,0,1,1,16-16A16,16,0,0,1,80,208ZM32,136V72H176v64Zm160,72a16,16,0,1,1,16-16A16,16,0,0,1,192,208Zm0-96V88h34.58l9.6,24Z'
          ></path>
        </svg>
        <p class='font-ibmplex-m'>Consegna gratuita</p>
        <p class='text-center max-w-[28ch]'>
          Consegna gratuita per ordini superiori a 6000€
        </p>
      </CardBenefit>
      <CardBenefit>
        <svg
          xmlns='http://www.w3.org/2000/svg'
          viewBox='0 0 256 256'
          height='64'
          width='64'
          fill='#ac1b1b'
          ><path
            d='M208,40H48A16,16,0,0,0,32,56v56c0,52.72,25.52,84.67,46.93,102.19,23.06,18.86,46,25.26,47,25.53a8,8,0,0,0,4.2,0c1-.27,23.91-6.67,47-25.53C198.48,196.67,224,164.72,224,112V56A16,16,0,0,0,208,40Zm-34.32,69.66-56,56a8,8,0,0,1-11.32,0l-24-24a8,8,0,0,1,11.32-11.32L112,148.69l50.34-50.35a8,8,0,0,1,11.32,11.32Z'
          ></path>
        </svg>
        <p class='font-ibmplex-m'>Garanzia estesa</p>
        <p class='text-center'>Garanzia di 7 invece di 5 anni</p>
      </CardBenefit>
      <CardBenefit>
        <svg
          xmlns='http://www.w3.org/2000/svg'
          viewBox='0 0 256 256'
          height='64'
          width='64'
          fill='#ac1b1b'
          ><path
            d='M240,208H224V136l2.34,2.34A8,8,0,0,0,237.66,127L139.31,28.68a16,16,0,0,0-22.62,0L18.34,127a8,8,0,0,0,11.32,11.31L32,136v72H16a8,8,0,0,0,0,16H240a8,8,0,0,0,0-16Zm-88,0H104V160a4,4,0,0,1,4-4h40a4,4,0,0,1,4,4Z'
          ></path>
        </svg>
        <p class='font-ibmplex-m'>Consulenza del progetto</p>
        <p class='text-center'>Consulenza gratuita all'acquisto</p></CardBenefit
      >
    </div>

    <h2 class='text-center mt-16'>Prodotti in offerta</h2>
    <p class='marginx text-center'>
      Una selezione curata dei nostri milgliori prodotti a prezzi eccezionali.
      Affrettati, le quantità sono limitate!
    </p>
    <div
      class='marginx grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-16 items-center justify-center mt-8'
    >
      <CardOfferteGenerator />
    </div>

    <!-- CTA -->
    <div class='marginx flex flex-col items-center gap-4 mt-32 pb-16'>
      <h2 class='text-center'>Non Perdere Queste Offerte!</h2>
      <p class='text-center max-w-[65ch]'>
        Le nostre promozioni sono a tempo limitate e le quantità sono limitate.
        Contattaci subito per non perdere l'opportunità di arredare la tua casa
        a prezzi vantaggiosi.
      </p>
      <Button type='1' to='/contatti'>Contattaci ora</Button>
    </div>
  </section>
</Layout>
