---
export interface Props {
  title: string;
  description: string;
  img: string;
}

const { title, description, img } = Astro.props;
---

<div
  class='relative w-full xl:w-1/4 aspect-square rounded-mara px-8 bg-size-[170%] bg-center hover:bg-size-[150%] transition-[background-size] ease'
  style={`background-image: 
      linear-gradient(180deg, transparent, rgba(0, 0, 0, 0.6) 63%),
      url('/images/${img}');`}
>
  <div class='absolute bottom-8'>
    <p class='font-ibmplex-m'>{title}</p>
    <p>{description}</p>
  </div>
</div>
