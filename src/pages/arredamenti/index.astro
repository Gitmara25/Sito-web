            img='card-complementi.jpg'
          />
        </ArredamentiCardContainer>
        <SliderArredamenti
          imgPath={[
            "camerette/camerette-1.jpg",
            "camerette/camerette-2.jpg",
            "camerette/camerette-3.jpg",
            "camerette/camerette-4.jpg",
            "camerette/camerette-5.jpg",
            "camerette/camerette-6.jpg",
          ]}
          alt={[
            "camerette-1",
            "camerette-2",
            "camerette-3",
            "camerette-4",
            "camerette-5",
            "camerette-6",
          ]}
        />
      </div>
    </div>
  </section>
</Layout>
