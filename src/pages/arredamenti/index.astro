            img='bagni/bagno-3.jpg'
          />
        </ArredamentiCardContainer>
        <SliderArredamenti
          imgPath={[
            "bagni/bagno-1.jpg",
            "bagni/bagno-2.jpg",
            "bagni/bagno-3.jpg",
            "bagni/bagno-4.jpg",
            "bagni/bagno-5.jpg",
            "bagni/bagno-6.jpg",
          ]}
          alt={[
            "bagno-1",
            "bagno-2",
            "bagno-3",
            "bagno-4",
            "bagno-5",
            "bagno-6",
          ]}
        />
      </div>

      <!-- camere -->
      <div id='camere'>
        <h2 class='text-center'>Camere</h2>
        <ArredamentiCardContainer>
          <CardArredamenti
            title='Camera'
            description='Il vostro rifugio personale per il riposo'
            img='card-camera.jpg'
          />
          <CardArredamenti
            title='Camera'
            description='Il vostro rifugio personale per il riposo'
            img='card-camera.jpg'
          />
          <CardArredamenti
            title='Camera'
            description='Il vostro rifugio personale per il riposo'
            img='card-camera.jpg'
          />
        </ArredamentiCardContainer>
        <SliderArredamenti
          imgPath={[
            "bagni/bagno-1.jpg",
            "bagni/bagno-2.jpg",
            "bagni/bagno-3.jpg",
            "bagni/bagno-4.jpg",
            "bagni/bagno-5.jpg",
            "bagni/bagno-6.jpg",
          ]}
          alt={[
            "bagno-1",
            "bagno-2",
            "bagno-3",
            "bagno-4",
            "bagno-5",
            "bagno-6",
          ]}
        />
      </div>

      <!-- camerette -->
      <div id='camerette'>
        <h2 class='text-center'>Camerette</h2>
        <ArredamentiCardContainer>
          <CardArredamenti
            title='Cameretta'
            description='Spazi che crescono coi vostri figli'
            img='camerette/camerette-1.jpg'
          />
          <CardArredamenti
            title='Cameretta'
            description='Spazi che crescono coi vostri figli'
            img='camerette/camerette-2.jpg'
          />
          <CardArredamenti
            title='Cameretta'
            description='Spazi che crescono coi vostri figli'
            img='camerette/camerette-3.jpg'
          />
        </ArredamentiCardContainer>
        <SliderArredamenti
          imgPath={[
            "camerette/camerette-1.jpg",
            "camerette/camerette-2.jpg",
            "camerette/camerette-3.jpg",
            "camerette/camerette-4.jpg",
            "camerette/camerette-5.jpg",
            "camerette/camerette-6.jpg",
          ]}
          alt={[
            "camerette-1",
            "camerette-2",
            "camerette-3",
            "camerette-4",
            "camerette-5",
            "camerette-6",
          ]}
        />
      </div>

      <!-- complementi -->
      <div id='complementi'>
        <h2 class='text-center'>Complementi</h2>
        <ArredamentiCardContainer>
          <CardArredamenti
            title='Complemento'
            description='Il tocco finale perfetto per la vostra casa'
            img='card-complementi.jpg'
          />
          <CardArredamenti
            title='Complemento'
            description='Il tocco finale perfetto per la vostra casa'
            img='card-complementi.jpg'
          />
          <CardArredamenti
            title='Complemento'
