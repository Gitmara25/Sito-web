---
import Layout from "../../layouts/Layout.astro";
import ArredamentiCardContainer from "./components/ArredamentiCardContainer.astro";
import CardArredamenti from "./components/CardArredamenti.astro";
import SliderArredamenti from "./components/SliderArredamenti.astro";
---

<style>
  #arredamenti div {
    margin-bottom: 4rem;
  }
</style>

<Layout
  metadescription='Scopri la nostra vasta collezione di mobili e accessori per la casa.'
>
  <section id='arredamenti'>
    <!-- <div
      class='bg-[url("/images/landing2.jpg")] bg-center bg-cover flex flex-col gap-4 items-center py-8'
    > -->
    <div class='bg-center bg-cover flex flex-col gap-4 items-center py-8'>
      <h1 class='text-center'>Arredamenti</h1>
      <p class='text-center'>
        Scopri la nostra vasta collezione di mobili e accessori per la casa.
      </p>
    </div>

    <div class='marginx'>
      <!-- cucine -->
      <div id='cucine'>
        <h2 class='text-center'>Cucine</h2>
        <ArredamentiCardContainer>
          <CardArredamenti
            title='Cucina'
            description='Il cuore pulsante della tua casa'
            img='cucine/cucina-1.jpg'
          />
          <CardArredamenti
            title='Cucina'
            description='Il cuore pulsante della tua casa'
            img='cucine/cucina-2.jpg'
          />
          <CardArredamenti
            title='Cucina'
            description='Il cuore pulsante della tua casa'
            img='cucine/cucina-3.jpg'
          />
        </ArredamentiCardContainer>
        <SliderArredamenti
          imgPath={[
            "cucine/cucina-1.jpg",
            "cucine/cucina-2.jpg",
            "cucine/cucina-3.jpg",
            "cucine/cucina-4.jpg",
            "cucine/cucina-5.jpg",
            "cucine/cucina-6.jpg",
          ]}
          alt={[
            "cucina-1",
            "cucina-2",
            "cucina-3",
            "cucina-4",
            "cucina-5",
            "cucina-6",
          ]}
        />
      </div>

      <!-- soggiorni -->
      <div id='soggiorni'>
        <h2 class='text-center'>Soggiorni</h2>
        <ArredamentiCardContainer>
          <CardArredamenti
            title='Soggiorno'
            description='Spazi disegnati per il relax e connessioni'
            img='soggiorni/soggiorno-3.jpg'
          />
          <CardArredamenti
            title='Soggiorno'
            description='Spazi disegnati per il relax e connessioni'
            img='soggiorni/soggiorno-5.jpg'
          />
          <CardArredamenti
            title='Soggiorno'
            description='Spazi disegnati per il relax e connessioni'
            img='soggiorni/soggiorno-6.jpg'
          />
        </ArredamentiCardContainer>
        <SliderArredamenti
          imgPath={[
            "soggiorni/soggiorno-1.jpg",
            "soggiorni/soggiorno-2.jpg",
            "soggiorni/soggiorno-3.jpg",
            "soggiorni/soggiorno-4.jpg",
            "soggiorni/soggiorno-5.jpg",
            "soggiorni/soggiorno-6.jpg",
          ]}
          alt={[
            "soggiorno-1",
            "soggiorno-2",
            "soggiorno-3",
            "soggiorno-4",
            "soggiorno-5",
            "soggiorno-6",
          ]}
        />
      </div>

      <!-- bagni -->
      <div id='bagni'>
        <h2 class='text-center'>Bagni</h2>
        <ArredamentiCardContainer>
          <CardArredamenti
            title='Bagno'
            description='La tua oasi di benessere personale '
            img='bagni/bagno-1.jpg'
          />
          <CardArredamenti
            title='Bagno'
            description='La tua oasi di benessere personale'
            img='bagni/bagno-2.jpg'
          />
          <CardArredamenti
            title='Bagno'
