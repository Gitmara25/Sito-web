---
import SvgWrapper from "./components/SvgWrapper.astro";
import Layout from "../../layouts/Layout.astro";
import ContattiWrapper from "./components/ContattiWrapper.astro";
import TextWrapper from "./components/TextWrapper.astro";
---

<script>
  //Script per URL dinamico
  const params = new URLSearchParams(window.location.search);
  const prod = params.get("prod");
  if (prod) {
    const messaggioElement = document.getElementById(
      "messaggio"
    ) as HTMLInputElement;
    if (messaggioElement) {
      messaggioElement.value = `Salve, sarei interessato a ${prod}`;
    }
  }
</script>

<style>
  input,
  textarea {
    background-color: white;
    border-radius: 12px;
    color: black;
    padding: 0.5rem;
    outline: none;
  }
  input[type="text"] {
    height: 3rem;
  }
  textarea {
    height: 10rem;
    resize: none;
  }
</style>

<Layout metadescription='meta description for SEO, EDIT IT'>
  <section class='marginx flex flex-col items-center'>
    <h1 class='text-center'>Contatti</h1>
    <p class='text-center max-w-[50ch]'>
      Siete pronti a trasformare la vostra casa? Saremo lieti di ascoltarvi.
      Contattateci oggi stesso per una consulenza personalizzata e scoprite come
      possiamo dare vita alla vostra visione.
    </p>

    <div
      class='flex flex-col-reverse lg:flex-row gap-8 lg:gap-[10%] w-full justify-between mt-20 mb-30'
    >
      <!-- Form contatti ala sinistra -->
      <div class='flex-1 flex flex-col'>
        <h2>Inviaci un messaggio</h2>
        <form
          action='#'
          id='contact-form-sito'
          method='post'
          class='grid grid-cols-2 gap-4 flex-1'
        >
          <label for='nome' class='self-end'>Nome</label>
          <label for='cognome' class='self-end'>Cognome</label>
          <input type='text' name='nome' id='nome' maxlength='50' required />
          <input
            type='text'
            name='cognome'
            id='cognome'
            maxlength='50'
            required
          />
          <label for='messaggio' class='self-end'>Messaggio</label>
          <textarea
            name='messaggio'
            id='messaggio'
            class='row-start-4 col-span-2'
            maxlength='1000'
            required></textarea>
          <div class='flex gap-4 items-center row-start-5'>
            <input
              type='checkbox'
              name='privacypolicy'
              id='privacypolicy'
              class='accent-red-700'
              required
            />
            <label for='privacypolicy'>Accetto la privacy policy</label>
          </div>

          <button
            class='bg-red-800 py-3 px-8 text-white rounded-mara font-ibmplex-m hover:bg-red-900 hover:text-red-200 transition-colors row-start-6 col-span-2'
            type='submit'>Invia un messaggio</button
          >
        </form>
      </div>
      <!-- Contatti Ala destra -->
      <div class='flex flex-col gap-8'>
        <div class='flex flex-col sm:flex-row lg:flex-col gap-8'>
          <ContattiWrapper>
            <SvgWrapper>
              <svg
                xmlns='http://www.w3.org/2000/svg'
                fill='none'
                viewBox='0 0 24 24'
                stroke-width='1.5'
                stroke='currentColor'
                class='size-8 lg:size-16'
              >
                <path
                  stroke-linecap='round'
                  stroke-linejoin='round'
                  d='M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z'></path>
                <path
                  stroke-linecap='round'
                  stroke-linejoin='round'
                  d='M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z'
                ></path>
              </svg>
            </SvgWrapper>
            <TextWrapper>
              <p class='font-ibmplex-b'>Da.Ma. S.n.c.</p>
              <a
                href='https://maps.google.com/?q=Via+Dante+8,+Mirano+30035+VE'
                target='_blank'>Via Dante 8, Mirano 30035 (VE)</a
              >
              <p>P.IVA: 03508030271</p>
              <a href='tel:+390415701702'>Tel: 0415701702</a>
              <a href='mailto:arredamenti.mara@libero.it'
                >Email: arredamenti.mara@libero.it</a
              >
            </TextWrapper>
          </ContattiWrapper>
          <ContattiWrapper>
            <SvgWrapper>
              <svg
                xmlns='http://www.w3.org/2000/svg'
                fill='none'
                viewBox='0 0 24 24'
                stroke-width='1.5'
                stroke='currentColor'
                class='size-8 lg:size-16'
              >
                <path
                  stroke-linecap='round'
                  stroke-linejoin='round'
                  d='M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z'></path>
              </svg>
            </SvgWrapper>
            <TextWrapper>
              <p class='font-ibmplex-b'>Orari</p>
              <p>Dal lunedì al sabato</p>
              <p>09 - 12:30, 15:30 - 19:30</p>
              <p>domenica - chiuso</p>
            </TextWrapper>
          </ContattiWrapper>
        </div>
        <img src='/images/google-maps.jpg' alt='google maps' />
      </div>
    </div>
  </section>
</Layout>
