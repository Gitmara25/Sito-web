---
const allSettings = await Astro.glob("../contentPageCMS/global-settings.md");
const globalSettings = allSettings[0]?.frontmatter.dataScadenzaOfferte;
const date = globalSettings
  ? new Date(globalSettings).toLocaleDateString("it-IT", {
      day: "numeric",
      month: "long",
      year: "numeric",
    })
  : "";
---

<span
  class='px-4 py-2 bg-white text-red-700 ml-4 rounded-mara inline-block mt-2 sm:mt-0'
  >{date}</span
>
