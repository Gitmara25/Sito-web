---
interface Props {
  link: string;
  classCSS: string;
}
const { link = "", classCSS = "" } = Astro.props;

//Separatori:
//- per gli spazi tra le lettere
//, per i nuovi link del menù
//§ per un link a tendina
//  ; per i nuovi sub link del menù a tendina
//Esempio: link='home,chi-siamo,arredamenti§cucine;soggiorni;bagni;camere;camerette,offerte,contatti'

type Link =
  | { type: "link"; label: string }
  | { type: "dropdown"; label: string; children: string[] };

function parseLinks(str: string): Link[] {
  return str.split(",").map((item) => {
    if (item.includes("§")) {
      const [parent, sublinks] = item.split("§");
      return {
        type: "dropdown",
        label: parent,
        children: sublinks.split(";"),
      };
    }
    return { type: "link", label: item };
  });
}

const links = parseLinks(link);
---

<nav class=`${classCSS} justify-around items-center gap-8`>
  {
    links.map((item) => {
      if (item.type === "dropdown") {
        return (
          <div class='dropdown'>
            <div class='flex items-center gap-2 relative dropbtn'>
              <a class='capitalize' href={`/${item.label}`}>
                {item.label}
              </a>
              <svg
                xmlns='http://www.w3.org/2000/svg'
                fill='none'
                viewBox='0 0 24 24'
                stroke-width='1.5'
                stroke='currentColor'
                class='size-4'
              >
                <path
                  stroke-linecap='round'
                  stroke-linejoin='round'
                  d='m19.5 8.25-7.5 7.5-7.5-7.5'
                />
              </svg>
            </div>
            <div class='dropdown-content'>
              {item.children.map((sub) => (
                <a class='capitalize' href={`/${item.label}#${sub}`}>
                  {sub}
                </a>
              ))}
            </div>
          </div>
        );
      }

      // Simple link
      return (
        <div>
          <a
            class='capitalize'
            href={`/${item.label === "home" ? "" : item.label}`}
          >
            {item.label.replace("-", " ")}
          </a>
        </div>
      );
    })
  }
</nav>

<style>
  .dropdown {
    z-index: 999;
  }

  .dropbtn {
  }
  .dropdown-content {
    display: none;
    position: absolute;
    min-width: 160px;
    background-color: var(--color-black);
  }

  .dropdown-content a {
    color: var(--color-white);
    padding: 12px 16px;
    text-decoration: none;
    display: block;
    border-left: 1px solid var(--color-white);
  }

  .dropdown-content:hover a:hover {
    transform: translateX(15px);
    text-decoration: underline;
    border-left: none;
  }

  .dropdown:hover .dropdown-content {
    display: block;
  }
</style>
